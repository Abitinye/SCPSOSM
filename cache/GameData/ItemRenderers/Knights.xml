<?xml version="1.0"?>
<ItemRenderer>
  <Data>
    <Sprite name="s_hit" fileName="game/Knights_Eff.rttex" textureSize="64" frame="0,0" />
    <Sprite name="s_sword" fileName="game/Knights.rttex" textureSize="128" frame="0,0" />
    <Sprite name="s_PunchCurve" fileName="game/Knights.rttex" textureSize="128" />
    <Sprite name="aura" fileName="game/Knights_Eff.rttex" textureSize="64" />
    
    <Animations>
      <SpriteAnimation name="hit" sprite="s_hit" animTime="400" autoPlay="true" isLoop="false">
        <Frame>0,0</Frame>
        <Frame>1,0</Frame>
        <Frame>0,1</Frame>
        <Frame>1,1</Frame>
      </SpriteAnimation>
		<SpriteAnimation name="PunchCurve" playOnAction="PUNCH" sprite="s_PunchCurve" animTime="400" isLoop="true">
		<Frame>0,1</Frame>
        <Frame>1,1</Frame>
        <Frame>2,1</Frame>
        <Frame>0,2</Frame>
        <Frame>1,2</Frame>
        <Frame>2,2</Frame>
      </SpriteAnimation>
      <SpriteAnimation name="aura" sprite="aura" animTime="300" autoPlay="true" isLoop="true">
		<Frame>0,2</Frame>
        <Frame>1,2</Frame>
        <Frame>2,2</Frame>
        <Frame>3,2</Frame>
        <Frame>4,2</Frame>
      </SpriteAnimation>
	</Animations>
	
    <RenderOptions>
      <Default>
        <Set name="PunchSoundOverride">HAND</Set>
        <Set name="PlayDefaultPunchAudio">false</Set>
        <Set name="DefaultRenderMannequinHandItem">false</Set>
        <Set name="RenderBackArmBuild">false</Set>
        <Set name="RenderBackArmInfected">true</Set>
        <Set name="RenderFrontArmInfected">true</Set>
        <Set name="UserNameOffset">15</Set>
        <Set name="IgnoreDefaultDamagedTileEffect">true</Set>
      </Default>
    </RenderOptions>
    
    <StateMachines>
      <StateMachine name="Punch">
        <States>
          <State name="False" />
          <State name="True" />
        </States>
        <Transitions>
          <Transition from="False" to="True">
            <Condition>
              <IsAction>PUNCH</IsAction>
            </Condition>
          </Transition>
          <Transition from="True" to="False">
            <Condition>
              <IsAction operatorType="NotEqual">PUNCH</IsAction>
            </Condition>
          </Transition>
        </Transitions>
      </StateMachine>
    </StateMachines>
    
    <ParticleSystems>
      <ParticleSystem name="punch_projectile" updateStage="OnPunchStart">
				<Emitter>
					<Random name="offset" min="32, -48" max="32, 16"/>
					<Set name="lifeTime">1</Set>
					<Set name="particlesPerEmission">1</Set>
				</Emitter>
				<Particle>
					<Set name="sprite">s_hit</Set>
					<Set name="rotateWithVelocity">true</Set>
					<Set name="lifeTime">0.4</Set>
					<VectorTo name="initialVelocity" source="targetPos" duration="lifeTime" x="1"/>
				</Particle>
			</ParticleSystem>
    </ParticleSystems>
  </Data>
  
  <RenderRules>
    <Update>
      <StopIf>
        <IsZombified>true</IsZombified>
      </StopIf>
      <AvatarTransform class="ArmAngle" onState="Punch.False">
        <Set name="armName">arm1Angle</Set>
        <Set name="armAngle">215</Set>
      </AvatarTransform>
    </Update>
    <RenderInFront>
      <StopIf>
        <IsZombified>true</IsZombified>
      </StopIf>
      <SpriteRender name="s_PunchCurve" offset="0,-15" alignment="CENTER" rotateOffset="true"  blend="PREMULTIPLIED_ALPHA" playOnAction="PUNCH" drawShadow="false" />
      <SpriteRender name="aura" offset="0,-32" blend="PREMULTIPLIED_ALPHA"/>
    </RenderInFront>
    <RenderBackHandItem>
      <StopIf type="and">
        <IsZombified>true</IsZombified>
        <IsAction>PUNCH</IsAction>
      </StopIf>
      <SpriteRender name="s_sword" offset="12, 2" rotationPoint="0,1" alignment="CENTER" rotateOffset="true" blend="PREMULTIPLIED_ALPHA" />
    </RenderBackHandItem>
    <OnPunchUpdate>
      <StopIf>
        <IsZombified>true</IsZombified>
      </StopIf>
      <AvatarTransform class="Emotion">
        <Set name="emotion">ANGRY</Set>
      </AvatarTransform>
      <AvatarTransform class="ArmAngle">
        <Set name="armName">arm1Angle</Set>
        <Set name="animTime">400</Set>
        <Set name="Curve">
          <KeyFrame>0.0, 215</KeyFrame>
          <KeyFrame>0.3, 360</KeyFrame>
          <KeyFrame>0.8, 360</KeyFrame>
          <KeyFrame>0.81, 215</KeyFrame>
          <KeyFrame>1, 215</KeyFrame>
        </Set>
      </AvatarTransform>
      <AvatarTransform class="ArmAngle">
        <Set name="armName">arm2Angle</Set>
        <Set name="armAngle">45</Set>
      </AvatarTransform>
    </OnPunchUpdate>
    <SwitchOffClothingParticles>
      <ParticleSystemOff name="punch_projectile"/>
    </SwitchOffClothingParticles>
  </RenderRules>
</ItemRenderer>
