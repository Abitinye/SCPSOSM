<?xml version="1.0" encoding="utf-8"?>
<ItemRenderer>
  <Data>
    <Sprite name="item_Sprite" fileName="game/SukunaDomain.rttex" textureSize="128" frame="0,0"/>

    <Animations>
        <SpriteSinPulseAnimation name="item_stretch" sprite="item_Sprite">
			<Parameter name="scale.x">
				<Set name="offset">1</Set>
				<Set name="period">1500</Set>
				<Set name="scale">0.1</Set>
			</Parameter>
		</SpriteSinPulseAnimation>
		<SpriteSinPulseAnimation name="item_stretch" sprite="item_Sprite">
			<Parameter name="scale.y">
				<Set name="offset">1</Set>
				<Set name="period">1750</Set>
				<Set name="scale">0.1</Set>
			</Parameter>
		</SpriteSinPulseAnimation>
    </Animations>

    <RenderOptions>
      <Default>
        <Set name="IsToRenderParticlesWhenShrunken">true</Set>
      </Default>
    </RenderOptions>
  </Data>

  <RenderRules>
    <RenderBackpack>
      <SpriteRender name="item_Sprite" offset="0,-64" alignment="CENTER" blend="PREMULTIPLIED_ALPHA" drawShadow="false"/>
    </RenderBackpackt>
    <OnPunchUpdate>
      <AvatarTransform class="Emotion">
        <Set name="emotion">ANGRY</Set>
      </AvatarTransform>
    </OnPunchUpdate>
  </RenderRules>
</ItemRenderer>